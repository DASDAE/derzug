&lt;/style&gt;&lt;/head&gt;&lt;body style=" font-family:'Sans Serif'; font-size:16px; font-weight:400; font-style:normal;"&gt;
&lt;p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"&gt;This one &lt;span style=" font-weight:700;"&gt;annotates&lt;/span&gt; the patch. Click &amp;quot;a&amp;quot; to open annotations, and &amp;quot;s&amp;quot; to send them to next widget.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</text>
		<arrow id="13" start="(425.13888888888886, 597.8409090909091)" end="(426.04797979797974, 538.75)" fill="#c1272d" />
