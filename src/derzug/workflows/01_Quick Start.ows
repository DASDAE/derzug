&lt;/style&gt;&lt;/head&gt;&lt;body style=" font-family:'Sans Serif'; font-size:16px; font-weight:400; font-style:normal;"&gt;
&lt;p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"&gt;Various  widgets can apply &lt;span style=" font-weight:700;"&gt;processing&lt;/span&gt; or&lt;span style=" font-weight:700;"&gt;  transformations&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</text>
