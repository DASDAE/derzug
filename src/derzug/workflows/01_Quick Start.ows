&lt;p align="center" style="-qt-paragraph-type:empty; margin-top:0px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"&gt;&lt;br /&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</text>
		<arrow id="1" start="(87.3636363636364, 253.63636363636363)" end="(88.2727272727273, 194.5454545454545)" fill="#1f9cdf" />
		<text id="2" type="text/html" rect="(30.27272727272728, 248.72727272727275, 150.0, 188.0)" font-family="Sans Serif" font-size="16">&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd"&gt;
