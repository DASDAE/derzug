		<text id="10" type="text/html" rect="(184.44444444444446, 600.0000000000002, 150.0, 166.0)" font-family="Sans Serif" font-size="16">&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd"&gt;
