		<text id="0" type="text/html" rect="(30.888888888888857, 46.777777777777786, 703.0, 78.0)" font-family="Sans Serif" font-size="16" font-alignment="center">&lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd"&gt;
