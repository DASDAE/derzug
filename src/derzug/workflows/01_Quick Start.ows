&lt;p style=" margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"&gt;This &lt;span style=" font-weight:700;"&gt;saves&lt;/span&gt; annotations.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</text>
